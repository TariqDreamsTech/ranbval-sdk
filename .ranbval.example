# Copy to .ranbval in your project root (add .ranbval to .gitignore).
# Loaded automatically on import ranbval_sdk — same idea as .env, no prompts for host/secret.

# Master password (plaintext in this file only — keep file private)
RANBVAL_VAULT_SECRET=your_dashboard_login_password

# Encrypted Ranbval token stays encoded here; plaintext API key exists only in memory during calls
OPENAI_API_KEY=ranbval.xxxxxxxx.[BLOB].ahsan

# Optional: other plaintext SDK envs
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: self-hosted password-manager origin (no /api). Omitted = hosted default in SDK.
# RANBVAL_HOST=http://127.0.0.1:8006
